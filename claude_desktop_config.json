{
  "_comment": "Add this block to ~/Library/Application Support/Claude/claude_desktop_config.json under 'mcpServers'",
  "mcpServers": {
    "cortex": {
      "command": "python",
      "args": ["/path/to/cortex/mcp_server.py"],
      "env": {
        "ANTHROPIC_API_KEY": "sk-ant-...",
        "GITHUB_TOKEN": "ghp_...",
        "CORTEX_REPO": "vamikasinghal/cortex-brain",
        "OPENAI_API_KEY": "sk-...",
        "REDIS_URL": "redis://localhost:6379"
      }
    }
  }
}
