# Cortex environment variables
# Copy to .env and fill in your values

# Anthropic (for extraction)
ANTHROPIC_API_KEY=sk-ant-...

# GitHub (for note storage)
GITHUB_TOKEN=ghp_...
CORTEX_REPO=vamikasinghal/cortex-brain   # your-username/repo-name
CORTEX_BRANCH=main

# OpenAI (for embeddings — or swap to Claude Embeddings)
OPENAI_API_KEY=sk-...

# Redis (default: local Docker)
REDIS_URL=redis://localhost:6379
